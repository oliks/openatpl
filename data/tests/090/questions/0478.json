  "questionNumber": "090-0478",
  "stemHtml": "<p>VHF signals are attenuated through the troposphere. At equal transmitter power, which signal suffers the least attenuation?</p>",
  "options": {
    "a": "<p>Air-to-air between two aircraft at 30,000 feet.</p>",
    "b": "<p>Ground-to-air to an aircraft at 30,000 feet.</p>",
    "c": "<p>Air-to-air between two aircraft at 10,000 feet.</p>",
    "d": "<p>Air-to-ground from 30,000 feet.</p>"
  },
  "correctOption": "a",
  "attachments": []
}
