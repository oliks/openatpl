    "a": "<p>Valencia Control, 5000 ft</p>",
    "b": "<p>Alicante Tower, 4000 ft</p>",
    "c": "<p>Valencia Control, 1000 ft</p>",
    "d": "<p>Alicante Tower,  2000 ft</p>"
  },
  "correctOption": "a",
