  "questionNumber": "081-1040",
  "stemHtml": "<p>Considering subsonic incompressible airflow and the Venturi effect, which of the following statements is correct for a mass flow through a constricted stream tube?</p>\r\n\r\n<ul>\r\n</ul>",
  "options": {
    "a": "<p>Velocity increases and static pressure decreases.</p>",
    "b": "<p>Velocity increases and static pressure increases.</p>",
    "c": "<p>Velocity decreases and static pressure decreases.</p>",
    "d": "<p>Velocity decreases and static pressure increases.</p>"
  },
  "correctOption": "a",
  "attachments": []
}
